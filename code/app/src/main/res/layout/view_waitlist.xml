<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/waitlist_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurface"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_waitlist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Waitlist"
        app:titleCentered="false"
        app:titleTextAppearance="@style/TextAppearance.Material3.HeadlineMedium" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_search_waitlist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Search Entrants"
        app:boxBackgroundColor="@color/colorSearchBar"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusBottomEnd="28dp"
        app:boxCornerRadiusBottomStart="28dp"
        app:boxCornerRadiusTopEnd="28dp"
        app:boxCornerRadiusTopStart="28dp"
        app:endIconDrawable="@android:drawable/ic_menu_search"
        app:endIconMode="custom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_waitlist">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search_waitlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/waitlist_actions_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_search_waitlist">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_applicant"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="Add Applicant"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:backgroundTint="@color/dark_grey"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconPadding="6dp"
            app:iconTint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_run_lottery"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Run Lottery"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:backgroundTint="@color/dark_grey"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconPadding="6dp"
            app:iconTint="@android:color/white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_waitlist_entries"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/btn_invite_coorganizer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/waitlist_actions_row">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_waitlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="10dp"
            android:paddingBottom="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_invite_coorganizer"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="Invite Co-Organizer"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/dark_grey"
        app:cornerRadius="26dp"
        app:icon="@android:drawable/ic_input_add"
        app:iconPadding="8dp"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/waitlist_footer_row"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_waitlist_entries" />

    <LinearLayout
        android:id="@+id/waitlist_footer_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export_csv"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="Export as CSV"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/dark_grey"
            app:cornerRadius="26dp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconPadding="8dp"
            app:iconTint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_see_cancelled"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="See Cancelled Entrants"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:backgroundTint="@color/dark_grey"
            app:cornerRadius="26dp"
            app:icon="@android:drawable/ic_delete"
            app:iconPadding="8dp"
            app:iconTint="@android:color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
