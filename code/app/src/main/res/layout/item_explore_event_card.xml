<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorCardBackground"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Poster image spanning full width -->
        <ImageView
            android:id="@+id/ivExplorePoster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="Event poster" />

        <!-- Card content below image -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <!-- Host row: avatar + name + date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/exploreAvatarCircle"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/colorAvatarBackground"
                    app:strokeWidth="0dp">

                    <TextView
                        android:id="@+id/tvExploreAvatarLetter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="A"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimaryFixed"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/ivExploreAvatarImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="Host profile picture" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tvExploreHostName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Host Name"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvExploreDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="April 15, 2026"
                        android:textColor="@color/colorPrimaryFixed"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Event name -->
            <TextView
                android:id="@+id/tvExploreEventName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event Name"
                android:textColor="@color/colorTextPrimary"
                android:textStyle="bold"
                android:textSize="17sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="10dp" />

            <!-- Description -->
            <TextView
                android:id="@+id/tvExploreDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description text"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- Location row -->
            <LinearLayout
                android:id="@+id/llExploreLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/colorTextHint"
                    android:contentDescription="Location" />

                <TextView
                    android:id="@+id/tvExploreLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textColor="@color/colorTextHint"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
