<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/waitlistGroupHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/notification_grey"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/ivWaitlistGroupIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Waitlist icon"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="#494451" />

        <TextView
            android:id="@+id/tvWaitlistGroupTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="Event waitlisted"
            android:textColor="#2B2730"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardBackgroundColor="@color/notification_chip"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivWaitlistGroupChevron"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="Expand waitlist notifications"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#6B6573" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/waitlistGroupDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F8F5FB"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/waitlistItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

</LinearLayout>
