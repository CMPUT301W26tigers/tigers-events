<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/avatarCircle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/colorAvatarBackground"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvAvatarLetter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="A"
                android:textStyle="bold"
                android:textColor="@color/colorPrimaryPurpleDark"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvEventName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Event Name"
            android:textColor="@color/colorTextPrimary"
            android:textStyle="bold"
            android:textSize="15sp"
            android:ellipsize="end"
            android:maxLines="2"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintStart_toEndOf="@id/avatarCircle"
            app:layout_constraintTop_toTopOf="@id/avatarCircle"
            app:layout_constraintEnd_toStartOf="@id/cardThumb" />

        <TextView
            android:id="@+id/tvEventHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Event Host"
            android:textColor="@color/colorTextHint"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="2"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintStart_toEndOf="@id/avatarCircle"
            app:layout_constraintTop_toBottomOf="@id/tvEventName"
            app:layout_constraintEnd_toStartOf="@id/cardThumb" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mar 15, 2026"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toEndOf="@id/avatarCircle"
            app:layout_constraintTop_toBottomOf="@id/tvEventHost" />

        <TextView
            android:id="@+id/tvEventTimeSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" \u2022 "
            android:textColor="@color/colorTextHint"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/tvEventDate"
            app:layout_constraintTop_toTopOf="@id/tvEventDate"
            app:layout_constraintBottom_toBottomOf="@id/tvEventDate" />

        <TextView
            android:id="@+id/tvEventTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7:00 PM"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/tvEventTimeSeparator"
            app:layout_constraintTop_toTopOf="@id/tvEventDate"
            app:layout_constraintBottom_toBottomOf="@id/tvEventDate" />

        <TextView
            android:id="@+id/tvEntrantStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/avatarCircle"
            app:layout_constraintTop_toBottomOf="@id/tvEventDate" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardThumb"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/colorCardBackground"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Event image"
                android:scaleType="centerCrop"
                app:srcCompat="@android:drawable/ic_menu_gallery" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
